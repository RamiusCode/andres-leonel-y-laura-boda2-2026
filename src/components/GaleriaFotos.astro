---
// Galeria.astro
---

<section class="w-full pt-12 relative overflow-hidden">
    <div class="w-full relative" id="foto-galeria">
        <img
            src="/imagenes/fot1.webp"
            alt="Nuestra historia"
            class="w-full h-auto block"
            id="img-galeria"
        />
        <!-- 
        <div
            class="absolute inset-0 pointer-events-none"
            style="background: radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.5) 100%);"
        >
        </div> -->

        <div
            class="absolute top-0 left-0 right-0 h-32 pointer-events-none"
            style="background: linear-gradient(to bottom, rgba(201,169,97,0.08), transparent);"
        >
        </div>

        <div
            class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none"
            style="background: linear-gradient(to top, rgba(201,169,97,0.08), transparent);"
        >
        </div>

        <div
            id="marco-ext"
            class="absolute inset-5 md:inset-8 pointer-events-none"
            style="border: 1px solid rgba(201,169,97,0.4);"
        >
        </div>

        <div
            id="marco-int"
            class="absolute inset-7 md:inset-11 pointer-events-none"
            style="border: 1px solid rgba(201,169,97,0.2);"
        >
        </div>

        <div
            id="esq-tl"
            class="absolute top-5 md:top-8 left-5 md:left-8 pointer-events-none"
        >
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <path
                    d="M28 1H1V28"
                    stroke="#C9A961"
                    stroke-width="1.5"
                    stroke-opacity="0.8"></path>
                <circle cx="1" cy="1" r="2" fill="#C9A961" fill-opacity="0.8"
                ></circle>
            </svg>
        </div>

        <div
            id="esq-tr"
            class="absolute top-5 md:top-8 right-5 md:right-8 pointer-events-none rotate-90"
        >
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <path
                    d="M28 1H1V28"
                    stroke="#C9A961"
                    stroke-width="1.5"
                    stroke-opacity="0.8"></path>
                <circle cx="1" cy="1" r="2" fill="#C9A961" fill-opacity="0.8"
                ></circle>
            </svg>
        </div>

        <div
            id="esq-bl"
            class="absolute bottom-5 md:bottom-8 left-5 md:left-8 pointer-events-none -rotate-90"
        >
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <path
                    d="M28 1H1V28"
                    stroke="#C9A961"
                    stroke-width="1.5"
                    stroke-opacity="0.8"></path>
                <circle cx="1" cy="1" r="2" fill="#C9A961" fill-opacity="0.8"
                ></circle>
            </svg>
        </div>

        <div
            id="esq-br"
            class="absolute bottom-5 md:bottom-8 right-5 md:right-8 pointer-events-none rotate-180"
        >
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <path
                    d="M28 1H1V28"
                    stroke="#C9A961"
                    stroke-width="1.5"
                    stroke-opacity="0.8"></path>
                <circle cx="1" cy="1" r="2" fill="#C9A961" fill-opacity="0.8"
                ></circle>
            </svg>
        </div>

        <div
            id="destello"
            class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 pointer-events-none"
            style="background: linear-gradient(to bottom, rgba(201,169,97,0.6), transparent);"
        >
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        gsap.set("#foto-galeria", { opacity: 0 });
        gsap.set("#img-galeria", {
            scale: 1.15,
            transformOrigin: "center center",
        });
        gsap.set("#marco-ext", { opacity: 0, scale: 1.08 });
        gsap.set("#marco-int", { opacity: 0, scale: 1.08 });
        gsap.set(["#esq-tl", "#esq-tr", "#esq-bl", "#esq-br"], {
            opacity: 0,
            scale: 0.5,
        });
        gsap.set("#destello", {
            opacity: 0,
            scaleY: 0,
            transformOrigin: "top center",
        });

        ScrollTrigger.create({
            trigger: "#foto-galeria",
            start: "top 85%",

            onEnter: () => {
                const tl = gsap.timeline();

                tl.to(
                    "#foto-galeria",
                    { opacity: 1, duration: 1.8, ease: "power2.out" },
                    0,
                )
                    .to(
                        "#img-galeria",
                        { scale: 1, duration: 7, ease: "power1.out" },
                        0,
                    )
                    .to(
                        "#marco-ext",
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 2,
                            ease: "power3.out",
                        },
                        0.6,
                    )
                    .to(
                        "#marco-int",
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 2,
                            ease: "power3.out",
                        },
                        0.9,
                    )
                    .to(
                        ["#esq-tl", "#esq-tr", "#esq-bl", "#esq-br"],
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.8,
                            stagger: 0.12,
                            ease: "back.out(2)",
                        },
                        1.4,
                    )
                    .to(
                        "#destello",
                        {
                            opacity: 1,
                            scaleY: 1,
                            duration: 1,
                            ease: "power2.out",
                        },
                        1.8,
                    )
                    .to(
                        "#destello",
                        { opacity: 0, duration: 1.2, ease: "power2.in" },
                        2.8,
                    );

                gsap.to("#img-galeria", {
                    scale: 1.04,
                    duration: 14,
                    ease: "sine.inOut",
                    yoyo: true,
                    repeat: -1,
                    delay: 7,
                });
            },

            onLeaveBack: () => {
                gsap.killTweensOf("#img-galeria");
                gsap.set("#foto-galeria", { opacity: 0 });
                gsap.set("#img-galeria", { scale: 1.15 });
                gsap.set("#marco-ext", { opacity: 0, scale: 1.08 });
                gsap.set("#marco-int", { opacity: 0, scale: 1.08 });
                gsap.set(["#esq-tl", "#esq-tr", "#esq-bl", "#esq-br"], {
                    opacity: 0,
                    scale: 0.5,
                });
                gsap.set("#destello", { opacity: 0, scaleY: 0 });
            },
        });
    });
</script>

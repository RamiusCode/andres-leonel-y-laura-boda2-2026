---
// Despedida.astro
---

<section class="py-4 px-4 relative overflow-hidden">
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex justify-center mb-10" id="flores-arriba-despedida">
        <img
          src="/imagenes/Separadores.webp"
          alt="Flores decorativas"
          class="w-40 md:w-48 lg:w-56 h-auto object-contain opacity-90"
        />
      </div>

      <div
        class="relative backdrop-blur-sm bg-white/10 rounded-[2.5rem] border-2 border-[#C9A961]/20 p-10 md:p-12 lg:p-16"
        id="card-despedida"
      >
        <div
          class="absolute top-0 left-0 right-0 h-1/2 bg-gradient-to-b from-white/10 to-transparent rounded-t-[2.5rem] pointer-events-none"
        >
        </div>

        <div class="absolute top-4 left-4 w-16 h-16">
          <div
            class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-[#C9A961]/40 to-transparent"
          >
          </div>
          <div
            class="absolute top-0 left-0 w-0.5 h-full bg-gradient-to-b from-[#C9A961]/40 to-transparent"
          >
          </div>
        </div>
        <div class="absolute top-4 right-4 w-16 h-16">
          <div
            class="absolute top-0 right-0 w-full h-0.5 bg-gradient-to-l from-[#C9A961]/40 to-transparent"
          >
          </div>
          <div
            class="absolute top-0 right-0 w-0.5 h-full bg-gradient-to-b from-[#C9A961]/40 to-transparent"
          >
          </div>
        </div>
        <div class="absolute bottom-4 left-4 w-16 h-16">
          <div
            class="absolute bottom-0 left-0 w-full h-0.5 bg-gradient-to-r from-[#C9A961]/40 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 w-0.5 h-full bg-gradient-to-t from-[#C9A961]/40 to-transparent"
          >
          </div>
        </div>
        <div class="absolute bottom-4 right-4 w-16 h-16">
          <div
            class="absolute bottom-0 right-0 w-full h-0.5 bg-gradient-to-l from-[#C9A961]/40 to-transparent"
          >
          </div>
          <div
            class="absolute bottom-0 right-0 w-0.5 h-full bg-gradient-to-t from-[#C9A961]/40 to-transparent"
          >
          </div>
        </div>

        <div class="relative z-10" id="contenido-completo">
          <div id="titulo-despedida" class="mb-8">
            <h2
              class="font-charm text-3xl md:text-3xl lg:text-3xl text-[#C9A961] font-bold mb-4"
            >
              Querida Familia y Amigos
            </h2>
            <div class="flex items-center justify-center gap-3">
              <div
                class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#C9A961]"
              >
              </div>
              <div class="w-2 h-2 rounded-full bg-[#C9A961]"></div>
              <div
                class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#C9A961]"
              >
              </div>
            </div>
          </div>

          <!-- MENSAJES - VERDE → LAVANDA -->
          <div id="mensaje-despedida" class="space-y-6 mb-10">
            <p
              class="font-charm text-xl md:text-2xl lg:text-3xl text-[#8E7AB5] leading-relaxed"
            >
              Nos llena de felicidad poder compartir con ustedes este momento
              tan único y especial.
            </p>
            <p
              class="font-charm text-xl md:text-2xl lg:text-3xl text-[#8E7AB5] leading-relaxed"
            >
              Con la esperanza de que hagamos de este día un recuerdo
              inolvidable.
            </p>
            <p
              class="font-charm text-xl md:text-2xl lg:text-3xl text-[#8E7AB5] leading-relaxed"
            >
              Los esperamos con los corazones llenos de emoción, listos para
              celebrar el amor y crear memorias que permanezcan siempre en
              nuestros corazones.
            </p>

            <p
              class="font-charm text-xl md:text-2xl lg:text-3xl text-[#8E7AB5] leading-relaxed"
            >
              Nos llenará de alegría contar con tu presencia desde el primer
              instante de nuestra boda.
            </p>
          </div>

          <div
            class="flex items-center justify-center gap-4 my-10"
            id="linea-decorativa"
          >
            <div
              class="w-20 h-[1px] bg-gradient-to-r from-transparent via-[#C9A961] to-[#C9A961]"
            >
            </div>
            <div class="relative">
              <svg
                class="w-8 h-8 text-[#C9A961]"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                ></path>
              </svg>
            </div>
            <div
              class="w-20 h-[1px] bg-gradient-to-l from-transparent via-[#C9A961] to-[#C9A961]"
            >
            </div>
          </div>

          <div id="seccion-confirmar" class="mt-10">
            <p
              class="font-charm text-2xl md:text-3xl lg:text-4xl text-[#C9A961] font-bold mb-8"
              id="texto-confirmar"
            >
              Esperamos contar con tu presencia
            </p>

            <!-- BOTÓN ELEGANTE CON CÓDIGO -->
            <div class="flex justify-center mb-5" id="boton-confirmar">
              <a
                href="https://wa.me/59178762918?text=Me%20complace%20confirmar%20mi%20asistencia%20para%20la%20boda.%20Nos%20vemos%20pronto"
                target="_blank"
                rel="noopener noreferrer"
                class="boton-confirmar-elegante"
              >
                <span class="boton-icono">
                  <!-- Icono WhatsApp -->
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path
                      d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                    ></path>
                  </svg>
                </span>
                <span class="boton-texto font-charm text-lg"
                  >Confirmar Asistencia</span
                >
              </a>
            </div>

            <!-- NOTA DE CONFIRMACIÓN -->
            <div
              class="flex flex-col items-center gap-2 mt-1"
              id="nota-confirmacion"
            >
              <p class="font-charm text-xl md:text-lg text-[#C9A961]">
                Por favor confirmar asistencia hasta el:
                <span class="font-semibold text-xl text-[#C9A961]"
                  >1 de abril</span
                >
              </p>
              <p class="font-charm text-xl md:text-xl text-[#8E7AB5] max-w-sm">
                Tu respuesta nos permitirá preparar cada detalle con el amor y
                cuidado que esta celebración merece
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-center mt-10" id="flores-abajo-despedida">
        <img
          src="/imagenes/Separadores.webp"
          alt="Flores decorativas"
          class="w-40 md:w-48 lg:w-56 h-auto object-contain opacity-90"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#flores-arriba-despedida", { opacity: 0, y: 20 });
      gsap.set("#card-despedida", { opacity: 0, y: 30 });
      gsap.set("#flores-abajo-despedida", { opacity: 0, y: 20 });

      ScrollTrigger.create({
        trigger: "#flores-arriba-despedida",
        start: "top 85%",
        onEnter: () => {
          const tl = gsap.timeline();
          tl.to(
            "#flores-arriba-despedida",
            { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
            0,
          )
            .to(
              "#card-despedida",
              { opacity: 1, y: 0, duration: 1.2, ease: "power2.out" },
              0.2,
            )
            .to(
              "#flores-abajo-despedida",
              { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
              0.4,
            );

          gsap.to("#linea-decorativa svg", {
            scale: 1.15,
            duration: 2.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
          });

          gsap.to("#boton-confirmar .boton-confirmar-elegante", {
            y: -6,
            duration: 3,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
          });
        },
        onLeaveBack: () => {
          gsap.killTweensOf("#linea-decorativa svg");
          gsap.killTweensOf("#boton-confirmar .boton-confirmar-elegante");
          gsap.set("#flores-arriba-despedida", { opacity: 0, y: 20 });
          gsap.set("#card-despedida", { opacity: 0, y: 30 });
          gsap.set("#flores-abajo-despedida", { opacity: 0, y: 20 });
        },
      });
    });
  }
</script>

<style>
  #card-despedida {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #card-despedida:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(201, 169, 97, 0.2);
  }

  /* Botón elegante lavanda */
  .boton-confirmar-elegante {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 28px;
    background: linear-gradient(135deg, #8e7ab5, #b497bd);
    color: white;
    border-radius: 50px;
    text-decoration: none;
    border: 2px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 6px 20px rgba(142, 122, 181, 0.4);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    white-space: nowrap;
  }

  .boton-confirmar-elegante::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent,
      rgba(255, 255, 255, 0.25),
      transparent
    );
    transition: left 0.5s ease;
  }

  .boton-confirmar-elegante:hover::before {
    left: 100%;
  }

  .boton-confirmar-elegante:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 10px 28px rgba(142, 122, 181, 0.55);
    background: linear-gradient(135deg, #7a68a0, #a386aa);
  }

  .boton-confirmar-elegante:active {
    transform: translateY(-1px) scale(1.01);
  }

  .boton-icono {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .boton-texto {
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  /* Nota de confirmación */
  #nota-confirmacion {
    animation: fadeInUp 0.8s ease forwards;
    opacity: 0;
    animation-delay: 0.3s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
